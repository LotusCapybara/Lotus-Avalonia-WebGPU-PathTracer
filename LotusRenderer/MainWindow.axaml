<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:LotusRenderer.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        Width="1920" Height="1080"
        x:Class="LotusRenderer.MainWindow"
        Title="LotusRenderer">
        
        <Grid ColumnDefinitions="300, *" RowDefinitions="*, 28">
                <!-- Left Bar -->
                <views:SidePanel />
                
                <GridSplitter Grid.Row="0" Grid.Column="0" 
                              ResizeDirection="Columns"
                              ShowsPreview="True"
                              Background="DarkGray"
                              HorizontalAlignment="Right"
                              Width="5"
                        />
                
                <Grid Grid.Row="0" Grid.Column="1" RowDefinitions="Auto, *">
                        <views:ViewportToolbar Grid.Row="0" />
                
                        <!-- Viewport -->
                        <Border Background="Black" Grid.Row="1" Grid.Column="1">
                                <Image x:Name="imgViewport" Source="" 
                                       Stretch="Fill"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                />
                        </Border>
                </Grid>
                        
                
                <!-- Bottom Bar -->
                <Border Background="Gray" Grid.Row="1" Grid.ColumnSpan="2" >
                        <StackPanel Margin="8, 0" Orientation="Horizontal">
                                <TextBlock x:Name="textGPUName">GPU Name: Loading..</TextBlock>
                                <TextBlock x:Name="textFrameTime">Frame:</TextBlock>
                        </StackPanel>
                        
                </Border>
                
        </Grid>
        
        
</Window>
